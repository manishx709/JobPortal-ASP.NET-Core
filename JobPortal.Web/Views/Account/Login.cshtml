@model JobPortal.Web.Models.LoginDTO

<h2>Login</h2>

<form method="post">

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>

        <input asp-for="Password"
               type="password"
               class="form-control" />
    </div>
 

    <button type="submit"
            class="btn btn-primary">
        Login
    </button>

</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">
        @ViewBag.Error
    </p>
}