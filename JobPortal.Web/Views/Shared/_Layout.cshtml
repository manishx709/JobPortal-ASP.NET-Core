@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - JobPortal.Web
    </title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/JobPortal.Web.styles.css"
          asp-append-version="true" />

</head>


    <body>

        @if (TempData["success"] != null)
        {
            <div class="toast-container position-fixed top-0 end-0 p-3">

                <div class="toast show align-items-center text-bg-success border-0">

                    <div class="d-flex">

                        <div class="toast-body">

                            @TempData["success"]

                        </div>

                        <button type="button"
                                class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast">
                        </button>

                    </div>

                </div>

            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="toast-container position-fixed top-0 end-0 p-3">

                <div class="toast show align-items-center text-bg-danger border-0">

                    <div class="d-flex">

                        <div class="toast-body">

                            @TempData["error"]

                        </div>

                        <button type="button"
                                class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast">
                        </button>

                    </div>

                </div>

            </div>
        }

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">

            <div class="container">

                <a class="navbar-brand fw-bold fs-3"
                   asp-controller="Home"
                   asp-action="Index">

                    <i class="bi bi-briefcase-fill"></i>
                    JobPortal

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav ms-auto align-items-center">

                        <li class="nav-item me-2">

                            <a class="nav-link text-light"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        @if (Context.Session.GetString("JWToken") == null)
                        {
                            <li class="nav-item me-2">

                                <a class="btn btn-outline-light"
                                   asp-controller="Account"
                                   asp-action="Login">

                                    Login

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="btn btn-warning"
                                   asp-controller="Account"
                                   asp-action="Register">

                                    Register

                                </a>

                            </li>
                        }
                        else
                        {
                            var role =
                            Context.Session.GetString(
                            "UserRole");

                            @if (role == "Candidate")
                            {
                                <li class="nav-item me-2">

                                    <a class="btn btn-primary"
                                       asp-controller="Application"
                                       asp-action="MyApplications">

                                        My Applications

                                    </a>

                                </li>
                            }

                            @if (role == "Employer")
                            {
                                <li class="nav-item me-2">

                                    <a class="btn btn-success"
                                       asp-controller="Employer"
                                       asp-action="CreateJob">

                                        Create Job

                                    </a>

                                </li>

                                <li class="nav-item me-2">

                                    <a class="btn btn-info text-white"
                                       asp-controller="Employer"
                                       asp-action="Applications">

                                        Applicants

                                    </a>

                                </li>
                            }

                            <li class="nav-item me-2">

                                <button class="btn btn-outline-light"
                                        onclick="toggleDarkMode()">

                                    🌙

                                </button>

                            </li>

                            <li class="nav-item">

                                <a class="btn btn-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    Logout

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container-fluid">

        <div class="row">

            @if (Context.Session.GetString("JWToken") != null)
            {
                <div class="col-md-2 bg-dark text-white min-vh-100 p-4">

                    <h4 class="mb-4">

                        Dashboard

                    </h4>

                    <ul class="nav flex-column">

                        <li class="nav-item mb-3">

                            <a class="nav-link text-white"
                               asp-controller="Home"
                               asp-action="Index">

                                <i class="bi bi-house-fill"></i>
                                Home

                            </a>

                        </li>

                        @if (Context.Session.GetString("UserRole") == "Employer")
                        {
                            <li class="nav-item mb-3">

                                <a class="nav-link text-white"
                                   asp-controller="Employer"
                                   asp-action="CreateJob">

                                    <i class="bi bi-plus-circle-fill"></i>
                                    Create Job

                                </a>

                            </li>

                            <li class="nav-item mb-3">

                                <a class="nav-link text-white"
                                   asp-controller="Employer"
                                   asp-action="Applications">

                                    <i class="bi bi-people-fill"></i>
                                    Applicants

                                </a>

                            </li>
                        }

                        @if (Context.Session.GetString("UserRole") == "Candidate")
                        {
                            <li class="nav-item mb-3">

                                <a class="nav-link text-white"
                                   asp-controller="Application"
                                   asp-action="MyApplications">

                                    <i class="bi bi-file-earmark-text-fill"></i>
                                    My Applications

                                </a>

                            </li>
                        }

                        <li class="nav-item mt-4">

                            <a class="btn btn-danger w-100"
                               asp-controller="Account"
                               asp-action="Logout">

                                Logout

                            </a>

                        </li>

                    </ul>

                </div>

                <div class="col-md-10 p-4">

                    <main role="main">

                        @RenderBody()

                    </main>

                </div>
            }
            else
            {
                <div class="col-12">

                    <main role="main" class="p-4">

                        @RenderBody()

                    </main>

                </div>
            }

        </div>

    </div>

    <footer class="bg-dark text-white text-center p-4 mt-5">

        <p class="mb-0">

            © 2026 JobPortal | ASP.NET Core MVC Project

        </p>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        function toggleDarkMode()
        {
            document.body.classList.toggle(
                "dark-mode");
        }

    </script>

    @await RenderSectionAsync(
    "Scripts",
        required: false)

</body>

</html>