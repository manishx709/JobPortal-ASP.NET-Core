@model List<JobPortal.Web.Models.JobDTO>
<div class="p-5 mb-5 bg-dark text-white rounded-4 shadow">

    <div class="container-fluid py-5">

        <h1 class="display-5 fw-bold">
            Find Your Dream Job
        </h1>

        <p class="col-md-8 fs-4">

            Explore opportunities from top companies
            and apply easily through our Job Portal.

        </p>

    </div>

</div>


<form method="get"
      asp-action="Index"
      class="mb-5">

    <div class="row g-3">

        <div class="col-md-4">

            <input type="text"
                   name="search"
                   class="form-control form-control-lg"
                   placeholder="Search jobs..." />

        </div>

        <div class="col-md-4">

            <input type="text"
                   name="location"
                   class="form-control form-control-lg"
                   placeholder="Location..." />

        </div>

        <div class="col-md-2">

            <button type="submit"
                    class="btn btn-dark btn-lg w-100">

                <i class="bi bi-search"></i>
                Search

            </button>

        </div>

    </div>

</form>
<h1>Available Jobs</h1>
<p class="text-muted">
    Total Jobs: @Model.Count
</p>

@if (!Model.Any())
{
    <p>No jobs available.</p>
}
else
{
    <div class="row">

        @foreach (var job in Model)
        {
            <div class="col-md-6">

                <div class="card shadow-sm mb-4 h-100 border-0 rounded-4">

                    <div class="card-body p-4">

                        @if (!string.IsNullOrEmpty(job.CompanyLogo))
                        {
                            <img src="https://localhost:7101@job.CompanyLogo"
                                 class="mb-3 shadow-sm"
                                 style="width:70px;
                                height:70px;
                                object-fit:cover;
                                border-radius:12px;" />
                        }

                    <h3 class="card-title fw-bold">
                        @job.Title
                    </h3>

                        <p class="text-muted mb-2">

                            <i class="bi bi-building"></i>
                            @job.CompanyName

                        </p>

                        <p class="card-text">

                            @(job.Description.Length > 120
                                                ? job.Description.Substring(0, 120) + "..."
                                                : job.Description)

                </p>

                        <div class="mb-3">

                            <span class="badge bg-primary me-2">

                                <i class="bi bi-geo-alt-fill"></i>
                                @job.Location

                            </span>

                            <span class="badge bg-success">

                                ₹@job.Salary

                            </span>

                        </div>

                        <a asp-controller="Home"
                           asp-action="Details"
                           asp-route-id="@job.Id"
                           class="btn btn-dark rounded-pill">

                            View Details

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
}